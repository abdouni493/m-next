# ===================================================================
# SUPABASE CONFIGURATION - ENVIRONMENT VARIABLES
# ===================================================================
# Copy this file to .env.local and fill in your NEW database credentials
# Get these from: https://app.supabase.com/project/[project-id]/settings/api

# NEW DATABASE CONNECTION - Fill these with your NEW Supabase credentials
VITE_SUPABASE_URL=https://your-new-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-new-anon-key-starting-with-eyJ...

# Application Settings
VITE_APP_NAME=chargers Management System
VITE_API_URL=http://localhost:5000
VITE_ENVIRONMENT=development

# ===================================================================
# HOW TO GET YOUR CREDENTIALS:
# ===================================================================
# 1. Go to: https://app.supabase.com
# 2. Select your NEW project
# 3. Navigate to: Settings → API
# 4. Copy the "Project URL" → paste as VITE_SUPABASE_URL
# 5. Copy the "anon" key → paste as VITE_SUPABASE_ANON_KEY
# 6. Save this file as .env.local
# 7. Restart the application (npm run dev)

# ===================================================================
# IMPORTANT NOTES:
# ===================================================================
# - Never commit .env.local to git (add to .gitignore)
# - Use VITE_SUPABASE_* prefix for Vite to pick them up
# - Changes require restarting the dev server
# - The old database URL will be removed from supabaseClient.ts
